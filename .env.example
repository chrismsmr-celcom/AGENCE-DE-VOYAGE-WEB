# .env - Version Amadeus

# Amadeus API (principal)
AMADEUS_API_KEY=votre_client_id_amadeus
AMADEUS_API_SECRET=votre_client_secret_amadeus

# Duffel API (fallback pour vols)
DUFFEL_TOKEN=your_duffel_token_here

# Supabase (base de données)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Booking.com via RapidAPI (fallback hôtels)
RAPIDAPI_KEY=your_rapidapi_key_here

# Configuration serveur
PORT=10000
NODE_ENV=production

# CORS - Origines autorisées
ALLOWED_ORIGINS=http://localhost:3333,https://terravoyage.com
