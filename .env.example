# .env.example - Copiez ce fichier vers .env et remplissez les valeurs

# Duffel API (vols et hôtels)
DUFFEL_TOKEN=your_duffel_token_here

# Supabase (base de données)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Lite API (fallback pour hôtels)
LITE_API_KEY=your_lite_api_key_here

# Configuration serveur
PORT=10000
NODE_ENV=production

# CORS - Origines autorisées (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3333,https://terravoyage.com

# Optionnel : clé API pour géocodage
GEOCODING_API_KEY=your_geocoding_api_key_here
